nmaku": 361, "source": "bilibili", "query": "新疆大学校园风光", "page": 1}, {"title": "新疆师范大学如何？是几本？值得报考吗？", "bvid": "BV1XS4y1H7TH", "url": "http://www.bilibili.com/video/av727791524", "author": "阿迪莱咯", "duration": "4:14", "duration_seconds": 254.0, "play": 34671, "description": "新疆师范大学如何？是几本？值得报考吗？", "intro": "", "tag": "校园,新疆,学习,记录,大学,万物皆可纪录,生活,文化,好喜欢我的日常,学校,情感", "typename": "日常", "pubdate": 1656249219, "favorites": 66, "review": 391, "danmaku": 37, "source": "bilibili", "query": "新疆大学校园风光", "page": 1}, {"title": "青春下一站，西部计划", "bvid": "BV1ZW4y1G7fz", "url": "http://www.bilibili.com/video/av947542651", "author": "中国青年志愿者", "duration": "6:18", "duration_seconds": 378.0, "play": 36087, "description": "什么样的青春，才是我们想要的样子？2003年以来，一批批像徐本禹、郎坤、安文忠、孟老强、黄鹏举一样的西部计划志愿者们，前赴后继、赓续奋斗，他们将青春梦想播撒在贵州的乡村教室、田间地头、基层一线……在贵州辽阔而广袤的土地上，到处闪动着西部计划志愿者的青春身影。（来源：团贵州省委）", "intro": "", "tag": "贵州,青春下一站，西部计划,志愿现场,致敬志愿者主题网络展播活动节目放送,直播,我在这里做志愿,致敬志愿者", "typename": "小剧场", "pubdate": 1673334872, "favorites": 850, "review": 24, "danmaku": 17, "source": "bilibili", "query": "新疆大学校园风光", "page": 1}, {"title": "山西师范大学校园风光", "bvid": "BV1Jk4y1k7wH", "url": "http://www.bilibili.com/video/av753068374", "author": "阿南儿645", "duration": "3:48", "duration_seconds": 228.0, "play": 5014, "description": "快来看看我们的学校风光，你能看出里面的路线图吗？\\n送给所有山西师范大学学生，同时祝学长学姐毕业快乐\\n（素材来源山西师范大学教育科学学院17级教育技术学19年视频作品）", "intro": "", "tag": "临汾,毕业季,高校,山西师范大学,大学生活", "typename": "日常", "pubdate": 1589007501, "favorites": 33, "review": 26, "danmaku": 6, "source": "bilibili", "query": "新疆大学校园风光", "page": 2}, {"title": "关于我从东南沿海的城市考到了最西北内陆之一的末流211这件事", "bvid": "BV1KntgzoEJx", "url": "http://www.bilibili.com/video/av114969530078668", "author": "baseacid", "duration": "1:35", "duration_seconds": 95.0, "play": 4742, "description": "想说的都在视频里\\n好想玩多次元宇宙融合论", "intro": "", "tag": "校园,录取通知书,生活记录,新疆大学,开箱,高考,晒晒我的录取通知书,大学", "typename": "原创音乐", "pubdate": 1754296045, "favorites": 11, "review": 113, "danmaku": 3, "source": "bilibili", "query": "新疆大学校园风光", "page": 2}, {"title": "新疆大学新校区参观20210719", "bvid": "BV1iU4y1n7D9", "url": "http://www.bilibili.com/video/av674318193", "author": "秦岭巍巍", "duration": "9:34", "duration_seconds": 574.0, "play": 61057, "description": "新疆大学新校区宿舍楼具体细节：（可能存在不同楼的差异，因为我只进入了一栋宿舍楼123层楼）\\n新校区宿舍大概是每栋宿舍楼都有一个洗澡堂在一层，每层楼都有净水热水器，一楼层还会有一个残疾人专属的卫生间。宿舍我看到的是六人间，取消了以前硌脚的直立梯子改变成台阶式梯子方便上下坐立。每栋宿舍楼每层卫生间至少六个洗手池，一层有洗衣房应该有最多十六个洗衣机。二层有配电室。最后，学校将在九月份前完工并交付，已经被录取的理工科学生（除软件学院外）和随校搬迁的院系将在新校区报道。欢迎大家来到新疆大学新校区。家人们！", "intro": "", "tag": "记录,校园,大学生,自制", "typename": "日常", "pubdate": 1626730779, "favorites": 115, "review": 509, "danmaku": 322, "source": "bilibili", "query": "新疆大学校园风光", "page": 2}, {"title": "新·大·博·达/飞跃新疆大学博达校区", "bvid": "BV16zn5zyEqn", "url": "http://www.bilibili.com/video/av115271771620939", "author": "锤中赤兔", "duration": "3:31", "duration_seconds": 211.0, "play": 1587, "description": "大家好，我是一名普通的新疆建筑设计师。这次有机会用航拍镜头记录下新疆大学博达校区，感受相当独特。\\n坦白说，站在专业角度，这里的每一栋单体的建筑设计或许并非都惊为天人，我也深知B站大神云集，不敢班门弄斧。但当我从空中俯瞰时，真正打动我的，是两大亮点：\\n1. 整个校园与环境的融合：建筑群落构成的节奏、道路绿地勾勒的尺度感，展现出一种宏大而宁静的秩序美。\\n2. 独一无二的壮丽背景：博达校区，窗外便是博格达峰。规划布局与远方雪山的对话关系，赋予了这片知识殿堂任何其他校园都无法复制的磅礴气韵。\\n这更像是一次纯粹的感", "intro": "", "tag": "大学,大学校园,新疆,摄影,原创,记录,新疆大学,B站超高清视频计划,校园,航拍", "typename": "出行", "pubdate": 1758907741, "favorites": 9, "review": 2, "danmaku": 0, "source": "bilibili", "query": "新疆大学校园风光", "page": 2}, {"title": "不要眨眼！带你第一视角看看咱的黑大校园！", "bvid": "BV1qN411E7Vf", "url": "http://www.bilibili.com/video/av491626880", "author": "黑龙江大学", "duration": "1:37", "duration_seconds": 97.0, "play": 11915, "description": "", "intro": "", "tag": "校园,第一视角", "typename": "日常", "pubdate": 1696384800, "favorites": 46, "review": 80, "danmaku": 4, "source": "bilibili", "query": "新疆大学校园风光", "page": 2}, {"title": "为了 211 名号去西藏大学值吗？", "bvid": "BV19mkxBeE4n", "url": "http://www.bilibili.com/video/av115914942976107", "author": "一只听音乐的猫", "duration": "2:56", "duration_seconds": 176.0, "play": 42878, "description": "要是都是为了名头去211，与其跑去西藏还不如去海南大学。\\n至少海南岛四季如春，海拔不高，空气清新，也没有啥特殊民族文化需要了解。而且最重要的是寒暑假都会错过进出岛高峰期，不用为进出岛问题担心。\\n\\n唯一不太好的是那地方比较养人，生活节奏太慢了，\\n待着待着很容易就被环境同化，变得没有在内地那么能卷了", "intro": "", "tag": "211 工程大学,bilibili期末季,西藏大学,考研,知识,大学,科普,一本大学,知乎话题,大学生", "typename": "日常", "pubdate": 1768743900, "favorites": 81, "review": 254, "danmaku": 23, "source": "bilibili", "query": "新疆大学校园风光", "page": 2}, {"title": "我镜头里的新疆大学", "bvid": "BV1eZ4y1A7Lu", "url": "http://www.bilibili.com/video/av374353584", "author": "丝路俄语-邓皓东", "duration": "5:48", "duration_seconds": 348.0, "play": 14062, "description": "要开学了！！！ 好吧，先把俄语放一边，把散落各手机、卡里的新大剪到一起。新的学期祝愿大家都有好成绩。", "intro": "", "tag": "新疆大学,开学", "typename": "校园学习", "pubdate": 1613719340, "favorites": 50, "review": 36, "danmaku": 7, "source": "bilibili", "query": "新疆大学校园风光", "page": 2}, {"title": "【学】喀什大学——新泉校区", "bvid": "BV1H54y1b7pU", "url": "http://www.bilibili.com/video/av844989284", "author": "武千里runner", "duration": "8:14", "duration_seconds": 494.0, "play": 23914, "description": "建筑是土黄色富有当地特色\\n风沙吹完依旧是土黄不显灰尘\\n窗口墙体突出较多 分割很密有效防晒\\n过道横梁也是防晒的", "intro": "", "tag": "生活记录,喀什大学", "typename": "日常", "pubdate": 1617850163, "favorites": 64, "review": 164, "danmaku": 8, "source": "bilibili", "query": "新疆大学校园风光", "page": 2}, {"title": "记录横跨中国来新疆大学的第一个学期", "bvid": "BV1RdJYzQERQ", "url": "http://www.bilibili.com/video/av114541727842627", "author": "希希曦兮_", "duration": "3:44", "duration_seconds": 224.0, "play": 1501, "description": "鄙人系生姜大学大一牲。\\n30多度的大热天没空调没风扇你新大win了：）", "intro": "", "tag": "记录,大学,随手记录我的生活碎片,生活记录,寻找100个宝藏vlogger3.0,校园,新疆大学,新疆,vlog", "typename": "电台", "pubdate": 1747768384, "favorites": 12, "review": 19, "danmaku": 4, "source": "bilibili", "query": "新疆大学校园风光", "page": 2}, {"title": "新疆大学Vlog 带你看看新疆大学研究生的生活记录 红湖 新疆大学北校区 俄语课  我的第一支校园Vlog", "bvid": "BV1kK4y1g7Si", "url": "http://www.bilibili.com/video/av888902092", "author": "远方的z", "duration": "3:53", "duration_seconds": 233.0, "play": 42916, "description": "在新疆大学北校区度过了愉快的一学期\\n这里的人都特别热情\\n饭菜也好吃\\n大盘鸡、烤包子、椒麻鸡、羊肉串\\n啊 不行了 我的口水都要流到键盘上咯\\n在这儿认识了许多许多的新朋友，和他们在一起真的很开心\\n下一期视频出在新疆的旅途经历\\n感谢大家支持哦", "intro": 